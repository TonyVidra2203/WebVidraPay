async def _binance_convert_quote_usdt_rub(
    api_key: str,
    api_secret: str,
    base_url: str,
    timeout: ClientTimeout = HTTP_TIMEOUT,
) -> Optional[float]:
    """
    Запросить котировку Binance Convert для 1 USDT → RUB. Возвращает RUB за 1 USDT.
    """
    try:
        ts = int(time.time() * 1000)
        params = {
            "fromAsset": "USDT",
            "toAsset": "RUB",
            "fromAmount": "1",
            "validTime": "30",
            "timestamp": str(ts),
        }
        qs = urlencode(params)
        sig = hmac.new(api_secret.encode(), qs.encode(), hashlib.sha256).hexdigest()
        url = f"{base_url.rstrip('/')}/sapi/v1/convert/getQuote?{qs}&signature={sig}"
        headers = {"X-MBX-APIKEY": api_key}

        async with ClientSession(timeout=timeout) as session:
            async with session.post(url, headers=headers) as resp:
                if resp.status != 200:
                    logger.error("Binance Convert HTTP %s", resp.status)
                    return None
                data: Dict[str, Any] = await resp.json(content_type=None)

        val = float(data.get("toAmount", 0))
        return val if val > 0 else None
    except Exception:
        logger.exception("Binance Convert getQuote failed")
        return None


async def get_usdt_rub_from_binance(
    api_key: str,
    api_secret: str,
    base_url: str,
    timeout: ClientTimeout = HTTP_TIMEOUT,
) -> Optional[float]:
    """
    Получить курс USDT/RUB: сперва через Binance Convert, затем fallback на Binance+MOEX.
    """
    val = await _binance_convert_quote_usdt_rub(api_key, api_secret, base_url, timeout)
    if val:
        return val
    return await get_usdt_rub_binance_moex(binance_base_url=base_url)


