async def get_btc_price() -> Optional[float]:
    """
    Получить последнюю цену BTCUSDT на Spot Bybit (с локальным кэшем).
    """
    global _btc_price, _btc_price_ts

    now = time.monotonic()
    if _btc_price is not None and (now - _btc_price_ts) < CACHE_TTL:
        return _btc_price

    data = await fetch_json(
        "https://api.bybit.com/v5/market/tickers",
        {"category": "spot", "symbol": "BTCUSDT"},
    )
    if not data or data.get("retCode") != 0:
        logger.error("Bybit API error: %s", data)
        return None

    tickers = data.get("result", {}).get("list", [])
    if not tickers:
        logger.error("Empty ticker list: %s", data)
        return None

    try:
        price = float(tickers[0]["lastPrice"])
    except (ValueError, KeyError, TypeError):
        logger.error("Invalid BTC price payload: %s", tickers[0] if tickers else None)
        return None

    _btc_price, _btc_price_ts = price, now
    return price


