async def clear_history(
    bot: Any,
    chat_histories: Dict[int, List[Tuple[int, int]]],
    user_id: int,
) -> None:
    """
    Удалить историю сообщений пользователя из chat_histories (игнорируя ошибки).
    """
    for chat_id, msg_id in chat_histories.pop(user_id, []):
        try:
            await bot.delete_message(chat_id, msg_id)
        except Exception:
            logger.warning("Failed to delete message %s in chat %s", msg_id, chat_id)

def get_order_commission_percent(rub_amount: Any) -> float:
    """
    Базовая комиссия обменника по сумме заявки:
    - до 10000 ₽ включительно: 25%
    - свыше 10000 ₽: 23%

    Оставлена отдельной функцией, чтобы позже можно было централизованно
    поменять пороги/ставки без поиска по проекту.
    """
    try:
        amount = float(rub_amount)
    except Exception:
        amount = 0.0

    return 25.0 if amount <= 10000.0 else 23.0

