async def get_usdt_rub_rate(ttl: int = CACHE_TTL) -> float:
    """
    Централизованный доступ к USDT/RUB:
      1) ручной курс из БД;
      2) локальный кэш;
      3) запасной курс из константы.
    """
    global _usdt_rub_rate, _usdt_rub_rate_ts

    now = time.monotonic()

    manual = await _get_rate_manual()
    if manual is not None and manual > 0:
        _usdt_rub_rate, _usdt_rub_rate_ts = float(manual), now
        return _usdt_rub_rate

    if _usdt_rub_rate is not None and (now - _usdt_rub_rate_ts) < ttl:
        return _usdt_rub_rate

    return float(USD_RUB_RATE)


async def get_usd_rub() -> float:
    """
    Совместимый с прошлым псевдоним — возвращает get_usdt_rub_rate().
    """
    return await get_usdt_rub_rate()


