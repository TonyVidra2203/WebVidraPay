async def get_binance_ticker_price(
    symbol: str,
    base_url: str = "https://api.binance.com",
    timeout: ClientTimeout = HTTP_TIMEOUT,
) -> Optional[float]:
    """
    Получить тикерную цену на Binance для символа (например, 'USDCUSDT').
    """
    url = f"{base_url.rstrip('/')}/api/v3/ticker/price"
    try:
        async with ClientSession(timeout=timeout) as session:
            async with session.get(url, params={"symbol": symbol}) as resp:
                if resp.status != 200:
                    logger.error("Binance ticker HTTP %s for %s", resp.status, symbol)
                    return None
                data: Dict[str, Any] = await resp.json(content_type=None)
                price = data.get("price")
                return float(price) if price is not None else None
    except Exception:
        logger.exception("Binance ticker fetch failed for %s", symbol)
        return None


async def get_moex_usd_rub(timeout: ClientTimeout = HTTP_TIMEOUT) -> Optional[float]:
    """
    Получить курс USD/RUB с MOEX по нескольким эндпоинтам (первая валидная цена).
    """

    async def _fetch(url: str) -> Optional[Dict[str, Any]]:
        try:
            async with ClientSession(timeout=timeout) as session:
                async with session.get(url) as resp:
                    if resp.status != 200:
                        logger.error("MOEX HTTP %s for %s", resp.status, url)
                        return None
                    payload: Dict[str, Any] = await resp.json(content_type=None)
                    return payload
        except Exception:
            logger.exception("MOEX fetch failed for %s", url)
            return None

    def _pick(payload: Dict[str, Any]) -> Optional[float]:
        md = payload.get("marketdata") or {}
        cols = md.get("columns") or []
        rows = md.get("data") or []
        if not rows:
            return None
        row = rows[0]
        idx = {name: i for i, name in enumerate(cols)}
        for field in ("LCURRENTPRICE", "MARKETPRICE", "LAST", "WAPRICE", "PREVPRICE"):
            i = idx.get(field)
            if i is None or i >= len(row):
                continue
            v = row[i]
            try:
                val = float(v)
                if val > 0:
                    return val
            except Exception:
                continue
        return None

    urls = [
        (
            "https://iss.moex.com/iss/engines/currency/markets/selt/boards/CETS/securities/"
            "USD000UTSTOM.json?iss.meta=off&iss.only=marketdata&"
            "marketdata.columns=SECID,LCURRENTPRICE,MARKETPRICE,LAST,PREVPRICE,WAPRICE"
        ),
        (
            "https://iss.moex.com/iss/engines/currency/markets/selt/boards/CETS/securities/"
            "USD000UTSTOM.json?iss.meta=off&iss.only=marketdata"
        ),
        (
            "https://iss.moex.com/iss/engines/currency/markets/selt/boards/CETS/"
            "securities.json?iss.meta=off&iss.only=marketdata&securities=USD000UTSTOM"
        ),
    ]
    for url in urls:
        payload = await _fetch(url)
        val = _pick(payload or {})
        if val and val > 0:
            return val

    trades_url = (
        "https://iss.moex.com/iss/engines/currency/markets/selt/boards/CETS/"
        "securities/USD000UTSTOM/trades.json?iss.meta=off"
    )
    payload = await _fetch(trades_url)
    trades = (payload or {}).get("trades") or {}
    cols = trades.get("columns") or []
    data = trades.get("data") or []
    if not data:
        return None

    last_row = data[-1]
    idx = {name: i for i, name in enumerate(cols)}
    i_price = idx.get("PRICE")
    if i_price is None or i_price >= len(last_row):
        return None

    try:
        price = float(last_row[i_price])
        return price if price > 0 else None
    except Exception:
        return None


async def get_usdt_rub_binance_moex(
    *,
    binance_base_url: str = "https://api.binance.com",
) -> Optional[float]:
    """
    Рассчитать USDT/RUB как (USDC/USDT на Binance) × (USD/RUB на MOEX).
    """
    usdc_usdt = await get_binance_ticker_price("USDCUSDT", binance_base_url)
    if not usdc_usdt:
        logger.error("USDCUSDT price unavailable")
        return None

    usd_rub = await get_moex_usd_rub()
    if not usd_rub:
        logger.error("MOEX USD/RUB unavailable")
        return None

    return usdc_usdt * usd_rub


