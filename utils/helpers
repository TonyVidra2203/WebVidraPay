_BASE58_ALPHABET = set("123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz")
_BECH32_CHARS = set("023456789acdefghjklmnpqrstuvwxyz")


def _normalize_wallet_input(wallet: Any) -> str:
    return str(wallet or "").strip()


def _is_base58_string(value: str) -> bool:
    return bool(value) and all(ch in _BASE58_ALPHABET for ch in value)


def _is_bech32_string(value: str) -> bool:
    return bool(value) and all(ch in _BECH32_CHARS for ch in value)


def validate_btc_wallet(wallet: Any) -> Tuple[bool, str]:
    value = _normalize_wallet_input(wallet)
    if not value:
        return False, "Введите BTC-кошелёк."

    if value.lower().startswith("bc1"):
        if value != value.lower() and value != value.upper():
            return False, "BTC-адрес формата bc1 не должен содержать смешанный регистр."
        low = value.lower()
        if not (14 <= len(low) <= 90):
            return False, "Некорректная длина BTC-адреса."
        if not _is_bech32_string(low[3:]):
            return False, "BTC-адрес содержит недопустимые символы."
        return True, ""

    if value[:1] not in {"1", "3"}:
        return False, "BTC-адрес должен начинаться с 1, 3 или bc1."

    if not (26 <= len(value) <= 62):
        return False, "Некорректная длина BTC-адреса."

    if not _is_base58_string(value):
        return False, "BTC-адрес содержит недопустимые символы."

    return True, ""


def validate_ltc_wallet(wallet: Any) -> Tuple[bool, str]:
    value = _normalize_wallet_input(wallet)
    if not value:
        return False, "Введите LTC-кошелёк."

    low = value.lower()

    if low.startswith("ltc1"):
        if value != value.lower() and value != value.upper():
            return False, "LTC-адрес формата ltc1 не должен содержать смешанный регистр."
        if not (14 <= len(low) <= 90):
            return False, "Некорректная длина LTC-адреса."
        if not _is_bech32_string(low[4:]):
            return False, "LTC-адрес содержит недопустимые символы."
        return True, ""

    if value[:1] not in {"L", "M", "3"}:
        return False, "LTC-адрес должен начинаться с L, M, 3 или ltc1."

    if not (26 <= len(value) <= 62):
        return False, "Некорректная длина LTC-адреса."

    if not _is_base58_string(value):
        return False, "LTC-адрес содержит недопустимые символы."

    return True, ""


def validate_usdt_wallet(wallet: Any) -> Tuple[bool, str]:
    value = _normalize_wallet_input(wallet)
    if not value:
        return False, "Введите USDT-кошелёк."

    # В текущем проекте web-ветка ориентируется на USDT(TRC20)
    if not value.startswith("T"):
        return False, "Для USDT в web-версии ожидается адрес формата TRC20, начинающийся с T."

    if len(value) != 34:
        return False, "Адрес USDT(TRC20) должен содержать 34 символа."

    if not _is_base58_string(value):
        return False, "Адрес USDT(TRC20) содержит недопустимые символы."

    return True, ""


def validate_wallet_for_asset(asset: Any, wallet: Any) -> Tuple[bool, str]:
    asset_u = str(asset or "").strip().upper()
    value = _normalize_wallet_input(wallet)

    if not value:
        return False, "Введите адрес кошелька."

    if asset_u == "BTC":
        return validate_btc_wallet(value)

    if asset_u == "LTC":
        return validate_ltc_wallet(value)

    if asset_u == "USDT":
        return validate_usdt_wallet(value)

    return False, f"Неподдерживаемая монета для проверки кошелька: {asset_u}"

