def _ff_sign(secret: str, data_json: str) -> str:
    """
    Подписать тело запроса для ff.io по схеме HMAC-SHA256.
    """
    return hmac.new(secret.encode(), data_json.encode(), hashlib.sha256).hexdigest()


async def ff_price_btc_to_usdt_to_amount(
    api_key: str,
    api_secret: str,
    *,
    usdt_ccy: str,
    amount_usdt: float,
    rate_type: Literal["float", "fixed"] = "fixed",
    timeout: ClientTimeout = HTTP_TIMEOUT,
    cache_ttl: int = _FF_PRICE_CACHE_TTL,
) -> Optional[Dict[str, Any]]:
    """
    Запрос цены ff.io (POST /api/v2/price) для получения amount_usdt USDT.

    По умолчанию используется тип курса "fixed", чтобы зафиксировать
    получаемое количество USDT. При необходимости можно явно передать
    rate_type="float", но в проекте дальше везде используем "fixed".
    Возвращает словарь с полями btc_in, usdt_out и raw либо None.
    """
    global _ff_cache_value

    if amount_usdt <= 0:
        return None

    payload = {
        "fromCcy": "BTC",
        "toCcy": usdt_ccy,
        "direction": "to",
        "amount": float(amount_usdt),
        "type": rate_type,
    }
    data_json = json.dumps(payload, separators=(",", ":"))

    now = time.monotonic()
    cache_key: Tuple[Any, ...] = ("ff_price_to", usdt_ccy, round(amount_usdt, 8), rate_type)
    if _ff_cache_value and _ff_cache_value[0] == cache_key and (now - _ff_cache_value[1]) < cache_ttl:
        return _ff_cache_value[2]

    headers = {
        "Accept": "application/json",
        "Content-Type": "application/json; charset=UTF-8",
        "X-API-KEY": api_key,
        "X-API-SIGN": _ff_sign(api_secret, data_json),
    }

    try:
        async with ClientSession(timeout=timeout) as session:
            async with session.post(_FF_PRICE_URL, data=data_json, headers=headers) as resp:
                ff: Dict[str, Any] = await resp.json(content_type=None)
    except Exception:
        logger.exception("ff.io price request failed")
        return None

    if not isinstance(ff, dict) or ff.get("code") != 0:
        logger.error("ff.io price error: %s", ff)
        return None

    data = ff.get("data") or {}
    try:
        btc_in = float(data.get("in"))
        usdt_out = float(data.get("out"))
        if btc_in <= 0 or usdt_out <= 0:
            raise ValueError("ff.io invalid in/out")
    except Exception:
        logger.error("ff.io invalid price payload: %s", data)
        return None

    result: Dict[str, Any] = {"btc_in": btc_in, "usdt_out": usdt_out, "raw": ff}
    _ff_cache_value = (cache_key, now, result)
    return result


async def btc_required_for_usdt_ff_float(
    *,
    api_key: str,
    api_secret: str,
    usdt_ccy: str,
    usdt_target: float,
    cache_ttl: int = _FF_PRICE_CACHE_TTL,
) -> Optional[float]:
    """
    Вернуть требуемый объём BTC на ff.io (тип fixed), чтобы получить usdt_target USDT.

    Имя функции сохранено для совместимости, но внутренне используется
    фиксированный курс ("fixed"), чтобы при заданной целевой сумме USDT
    на выходе пользователь получал именно её.
    """
    quote = await ff_price_btc_to_usdt_to_amount(
        api_key=api_key,
        api_secret=api_secret,
        usdt_ccy=usdt_ccy,
        amount_usdt=usdt_target,
        rate_type="fixed",
        cache_ttl=cache_ttl,
    )
    if not quote:
        return None
    return float(quote["btc_in"])
