async def convert_asset_to_usdt(
    asset: str,
    amount_asset: float,
    *,
    client: Optional[_BinanceClient] = None,
) -> float:
    """
    Конвертировать <ASSET> → USDT. Возвращает фактически полученные USDT.
    """
    c = _get_binance_client(client)
    try:
        return await c.convert_any_to_usdt(asset, amount_asset)
    except _BinanceAPIError as e:
        logger.error("convert_asset_to_usdt failed: %s", e)
        raise


async def convert_usdt_to_ton(
    usdt_amount: float,
    *,
    client: Optional[_BinanceClient] = None,
) -> float:
    """
    Конвертировать USDT → TON. Возвращает фактически купленный объём TON.
    """
    c = _get_binance_client(client)
    try:
        return await c.convert_usdt_to_ton(usdt_amount)
    except _BinanceAPIError as e:
        logger.error("convert_usdt_to_ton failed: %s", e)
        raise


async def convert_any_asset_to_ton(
    asset: str,
    amount_asset: float,
    *,
    client: Optional[_BinanceClient] = None,
) -> float:
    """
    Маршрут конвертации: <ASSET> → USDT → TON. Возвращает купленный объём TON.
    """
    c = _get_binance_client(client)
    usdt_amount = await convert_asset_to_usdt(asset, amount_asset, client=c)
    if usdt_amount <= 0:
        return 0.0
    ton_amount = await convert_usdt_to_ton(usdt_amount, client=c)
    return float(ton_amount)


